# Public site origin, without a trailing slash.
REACT_APP_PUBLIC_SITE_URL=http://localhost:3000

# Backend origin, without /api and without a trailing slash.
REACT_APP_BACKEND_URL=http://localhost:8000

# Third-party analytics are opt-in and production-only.
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_POSTHOG_KEY=
REACT_APP_POSTHOG_HOST=https://us.i.posthog.com
REACT_APP_ENABLE_SESSION_RECORDING=false

# Keep disabled unless the deployment platform requires it.
REACT_APP_ENABLE_EMERGENT_RUNTIME=false

# Recommended for public production builds unless private source maps are uploaded separately.
GENERATE_SOURCEMAP=false
