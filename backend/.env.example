MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=niuva
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Comma-separated exact frontend origins. Never use * with credentialed requests.
CORS_ORIGINS=https://www.example.com

# Enable only when the service runs behind a trusted proxy that overwrites X-Forwarded-For.
TRUST_PROXY_HEADERS=false

HRD_EMAIL=niuvamakerspace@gmail.com
APP_NAME=niuva

# Email notifications use Resend. Without a key, notifications remain in-app only.
RESEND_API_KEY=
SENDER_EMAIL=website@your-verified-domain.example

# Development/demo only. Relative paths resolve from backend/.
LOCAL_STORAGE_ROOT=.local-storage
