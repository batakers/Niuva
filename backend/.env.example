# Local mutation development requires docker-compose.transaction.yml (rs0).
MONGO_URL=mongodb://127.0.0.1:27017/?replicaSet=rs0&directConnection=true
DB_NAME=niuva
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Comma-separated exact frontend origins. Never use * with credentialed requests.
CORS_ORIGINS=https://www.example.com

# Enable only when the service runs behind a trusted proxy that overwrites X-Forwarded-For.
TRUST_PROXY_HEADERS=false

HRD_EMAIL=niuvamakerspace@gmail.com
APP_NAME=niuva

# Email notifications use Resend. Without a key, notifications remain in-app only.
RESEND_API_KEY=
SENDER_EMAIL=website@your-verified-domain.example

# File storage defaults to disabled. Local mode is development/demo/test only.
APP_ENV=development
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=.local-storage

# Tests only. CI supplies an isolated rs-test topology on port 27018.
MONGO_TRANSACTION_TEST_URL=mongodb://127.0.0.1:27018/?replicaSet=rs-test&directConnection=true

# Fail closed by default. Enable only after GET /api/health/ready reports transactions ready.
TRANSACTION_MUTATIONS_ENABLED=false
