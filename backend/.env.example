# MongoDB connection used by the API.
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=niuva

# Use a unique, random value of at least 32 characters in every environment.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# The account below is created (or its password updated) every time the API starts.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=bujang

# Exact, comma-separated frontend origins. Do not use *.
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY_HEADERS=false

HRD_EMAIL=niuvamakerspace@gmail.com
APP_NAME=niuva

# Email notifications use Resend. Leave empty to keep notifications in-app only.
RESEND_API_KEY=
SENDER_EMAIL=website@your-verified-domain.example

# Required only for the current object-storage integration.
EMERGENT_LLM_KEY=
